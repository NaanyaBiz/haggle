__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# uv
.uv/

# Type checkers / linters
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# IDE
.idea/
.vscode/
*.swp
