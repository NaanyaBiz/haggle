# OS
.DS_Store
Thumbs.db

# Claude Code (per-machine settings stay local)
.claude/settings.local.json
.claude/.credentials.json
# Local-only devops notes and private context (never reaches public repo)
.claude/local/

# Home Assistant dev artefacts
.HA_VERSION
config/

# Worktrees live as siblings (../haggle.wt/), not nested,
# but ignore the dir defensively in case someone tries the nested layout.
.worktrees/

# Local secrets (defence-in-depth; gitleaks also scans)
.env
.env.*
!.env.example
